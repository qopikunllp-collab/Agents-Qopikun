# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# Change this to any long random string for production
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Team passwords (optional — defaults are set in auth.js)
FOUNDER_PASS=qopi@founder
RANJITH_PASS=qopi@ranjith
ADMIN_PASS=qopi@admin
ACCOUNTS_PASS=qopi@accounts
RAGHAV_PASS=qopi@raghav

# Port (Render sets this automatically)
PORT=3000
